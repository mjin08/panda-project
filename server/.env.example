# Panda Diplomacy API — Environment Configuration
# Copy this file as .env and adjust values as needed.
#   cp .env.example .env

# Server
PORT=3001
NODE_ENV=development

# Database — SQLite file path relative to server/ directory
DB_PATH=./database/panda_diplomacy.db

# CORS — allow Vue dev server to communicate with API
CORS_ORIGIN=http://localhost:5173